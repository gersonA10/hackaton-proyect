# Copia este archivo a .env y completa los valores
PORT=3000
NODE_ENV=development

# NASA FIRMS — pide tu MAP_KEY gratis en:
# https://firms.modaps.eosdis.nasa.gov/api/map_key/
FIRMS_KEY=
# Bounding box de Bolivia: oeste,sur,este,norte (cubre todo el país)
FIRMS_BBOX=-70,-23,-57,-9
FIRMS_SOURCES=VIIRS_SNPP_NRT,VIIRS_NOAA20_NRT
FIRMS_DAYS=2

# Gemini — saca tu API key en:
# https://aistudio.google.com/apikey
GEMINI_KEY=
GEMINI_MODEL=gemini-2.5-flash

# SMS de alerta (Twilio) — OPCIONAL. Vacío = el envío se SIMULA.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_API_KEY_SID=
TWILIO_API_KEY_SECRET=
TWILIO_FROM=
